# Django
SECRET_KEY=your-secret-key-min-50-chars-change-this
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-server-ip

# Database
DB_NAME=pamp_db
DB_USER=pamp_user
DB_PASSWORD=strongpassword
DB_ROOT_PASSWORD=rootstrongpassword
DB_HOST=db
DB_PORT=3306

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Pasargad/Sigma Panel API
PANEL_BASE_URL=https://your-panel-domain.com
PANEL_USERNAME=your_panel_username
PANEL_PASSWORD=your_panel_password

# Sync interval in minutes
PANEL_SYNC_INTERVAL_MINUTES=15

# Django superuser (used by createsuperuser management command)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=changeme
DJANGO_SUPERUSER_EMAIL=admin@example.com
